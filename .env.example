# ── Frontend (Vite) ──────────────────────────────────────────
# Salin file ini menjadi .env.local lalu isi nilainya.
# Ambil dari Supabase: Project Settings → API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Edge Function: telegram-webhook ──────────────────────────
# JANGAN taruh di .env.local. Set lewat Supabase CLI / Dashboard:
#   supabase secrets set TG_TOKEN=... TG_CHAT=... SUPABASE_SERVICE_ROLE_KEY=...
# SUPABASE_URL & SUPABASE_SERVICE_ROLE_KEY otomatis tersedia di runtime
# edge function, tapi bisa juga di-set manual saat pengembangan lokal.
# TG_TOKEN  = token bot Telegram (dari @BotFather)
# TG_CHAT   = chat/grup ID tujuan notifikasi
